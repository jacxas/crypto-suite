# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Contract Addresses (after deployment)
VITE_TOKEN_ADDRESS=0x...
VITE_NFT_ADDRESS=0x...
